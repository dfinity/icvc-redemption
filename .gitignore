# DFX
.dfx/

# Mops dependencies
.mops/

# Node
node_modules/

# Frontend build artifacts (esbuild bundle)
src/frontend/js/dfinity.js

# Frontend runtime config (generated by scripts/deploy.sh from
# config.js.template; contains the target network's canister ids)
src/frontend/js/config.js

# DFX env file (generated, contains local canister IDs)
src/frontend/.env

# OS
.DS_Store

# Claude Code
.claude/

# icp-cli per-project cache (network state, build artifacts, identity-to-id mappings)
.icp/cache/

# PocketIC test harness virtualenv + Python cache
tests/pocketic/.venv/
tests/pocketic/__pycache__/
tests/pocketic/.pytest_cache/
tests/pocketic/mock_icp_ledger.wasm
tests/pocketic/mock_ledger.wasm

# Reproducible-build output (scripts/verify-wasm.sh --out / CI). The hash
# lives in redemption.wasm.sha256; the wasm itself is a build artifact.
redemption.wasm
